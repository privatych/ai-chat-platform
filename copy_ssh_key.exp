#!/usr/bin/expect -f
set timeout 10
set host [lindex $argv 0]
set password [lindex $argv 1]
set pubkey [lindex $argv 2]

spawn ssh -o StrictHostKeyChecking=no root@$host "mkdir -p ~/.ssh && chmod 700 ~/.ssh && echo \"$pubkey\" >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys"

expect {
    "*yes/no*" {
        send "yes\r"
        exp_continue
    }
    "*assword:*" {
        send "$password\r"
        exp_continue
    }
    eof
}
